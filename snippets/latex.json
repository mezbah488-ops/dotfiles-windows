{
	"Preamble": {
    "prefix": "preamble",
    "body": [
      "\\documentclass[11pt,a4paper]{article}",
      "",
      "% --- Page layout ---",
      "\\usepackage[margin=1in]{geometry}",
      "\\usepackage{microtype}",
      "\\usepackage{fancyhdr}",
      "\\setlength{\\headheight}{14pt}",
      "",
      "% --- Math ---",
      "\\usepackage{amsmath, amssymb, amsfonts}",
      "\\usepackage{amsthm}",
      "\\usepackage{mathtools}",
      "\\usepackage{bbold}",
      "\\usepackage{slashed}",
      "\\usepackage{braket}",
      "\\usepackage{cancel}",
      "",
      "% --- Theorems ---",
      "\\newtheorem{theorem}{Theorem}",
      "",
      "% --- Figures ---",
      "\\usepackage{graphicx}",
      "\\usepackage{float}",
      "\\usepackage{caption}",
      "\\usepackage{wrapfig}",
      "\\usepackage{import}",
      "\\usepackage{xifthen}",
      "\\usepackage{pdfpages}",
      "\\usepackage{transparent}",
      "\\newcommand{\\incfig}[2][1]{%",
      "\\edef\\svgwidth{#1\\columnwidth}",
      "\\import{./figures/}{#2.pdf_tex}",
      "}",
      "\\pdfsuppresswarningpagegroup=1",
      "",
      "% --- TikZ & PGF ---",
      "\\usepackage{tikz}",
      "\\usetikzlibrary{calc, intersections, arrows.meta, decorations.pathmorphing}",
      "\\usepackage{pgfplots}",
      "\\usepgfplotslibrary{fillbetween}",
      "\\pgfplotsset{compat=1.18}",
      "",
      "% --- Bibliography ---",
      "\\usepackage[backend=biber, style=numeric, sorting=nyt]{biblatex}",
      "\\addbibresource{${4:references.bib}}",
      "",
      "% --- Misc ---",
      "\\usepackage{soul}",
      "\\usepackage[colorlinks=true, linkcolor=blue, urlcolor=blue]{hyperref}",
      "\\usepackage{xurl}",
      "",
      "\\title{${1:Title}}",
      "\\author{${2:Author}}",
      "\\date{${3:Date}}",
      "",
      "\\begin{document}",
      "\\maketitle",
      "\\tableofcontents",
      "\\newpage",
      "$0",
      "",
      "\\printbibliography",
      "\\end{document}"
    ],
    "description": "Full LaTeX preamble"
  },
  "mdframed": {
    "prefix": "mdframe",
    "body": [
      "\\begin{mdframed}",
      "\t${1}",
      "\\end{mdframed}"
    ],
    "description": "mdframed environment"
  },
  "Centered Incfig [Half Scale]": {
    "prefix": "incfig_center",
    "body": "\\begin{center}\n\t$$\\vcenter{\\hbox{\\scriptsize \\incfig[0.5]{$1}}}$$\n\\end{center}${0}",
    "description": "Centered half-scale incfig figure"
  },
  "Textcolor": {
    "prefix": "color",
    "body": [
      "\\textcolor{${1:red}}{${2}}"
    ],
    "description": "Colored text with xcolor"
  },
  "vcenter incfig inline": {
    "prefix": "incfig_inline",
    "body": [
      "$\\vcenter{\\hbox{\\scriptsize \\incfig[0.5]{${1:}}}}$"
    ],
    "description": "Inline math vertically centered incfig"
  },
  "Inkscape Figure": {
    "prefix": "incfig",
    "body": [
      "\\begin{figure}[ht]",
      "\t\\centering",
      "\t\\incfig[${1:0.5}]{${2:figure_name}}",
      "\t\\caption{${3:Your caption here}}",
      "\\end{figure}"
    ],
    "description": "Insert Inkscape figure, optional arg is a scale factor (0 to 1)"
  },
  "Exercise (tcolorbox)": {
    "prefix": "ex",
    "body": [
      "\\begin{exercise}{${1}}{${2:label}}",
      "\t${3:Exercise content here...}",
      "\\end{exercise}"
    ],
    "description": "Insert tcolorbox exercise environment"
  },
  "Exercise Reference": {
    "prefix": "exref",
    "body": "\\ref{ex:${1:label}}",
    "description": "Reference an exercise by its label"
  },
  "LaTeX environment": {
    "prefix": "env",
    "body": [
      "\\begin{$1}",
      "\t$0",
      "\\end{$1}"
    ],
    "description": "Generic LaTeX environment with mirrored name"
  },
  "Reference": {
    "prefix": "ref",
    "body": "\\ref{${1}}${0}",
    "description": "Insert reference"
  },
  "2x2 Matrix": {
    "prefix": "mat2",
    "body": "\\begin{pmatrix}\n${1:a} & ${2:b} \\\\\n${3:c} & ${4:d}\n\\end{pmatrix}${0}",
    "description": "Insert 2x2 matrix"
  },
  "Matrix (generic)": {
    "prefix": "mat",
    "body": [
      "\\begin{${1:p}matrix}",
      "\t$0",
      "\\end{${1:p}matrix}"
    ],
    "description": "Matrix environment — replace 'p' with b/v/V/B/small as needed"
  },
  "Quad Space": {
    "prefix": "quad",
    "body": "\\quad${0}",
    "description": "Insert quad space in math mode"
  },
  "Theorem Environment": {
    "prefix": "thm",
    "body": "\\begin{theorem}[${1:title}]\n\t${2:statement}\n\\end{theorem}${0}",
    "description": "Insert theorem environment"
  },
  "Bold Nabla": {
    "prefix": "bnabla",
    "body": "\\boldsymbol{\\nabla}${0}",
    "description": "Insert boldface nabla symbol"
  },
  "Underset with Two Conditions": {
    "prefix": "us2",
    "body": "\\underset{\\substack{\\scriptstyle ${1:cond1}\\\\ \\scriptstyle ${2:cond2}}}{${3:expr}}${0}",
    "description": "Underset with two scriptstyle conditions"
  },
  "Underset with One Condition": {
    "prefix": "us1",
    "body": "\\underset{\\scriptstyle ${1:cond}}{${2:expr}}${0}",
    "description": "Underset with one scriptstyle condition"
  },
  "Underbrace": {
    "prefix": "under",
    "body": "\\underbrace{${1:expr}}_{${2:label}}${0}",
    "description": "Insert underbrace with label"
  },
  "Overset": {
    "prefix": "overset",
    "body": "\\overset{${1:above}}{${2:main}}${0}",
    "description": "Insert overset"
  },
  "Underset": {
    "prefix": "undset",
    "body": "\\underset{${1:below}}{${2:main}}${0}",
    "description": "Insert underset"
  },
  "Second Order Derivative": {
    "prefix": "d2",
    "body": "\\frac{d^{2} ${1:y}}{d ${2:x}^{2}}${0}",
    "description": "Second derivative d²y/dx²"
  },
  "Third Order Derivative": {
    "prefix": "d3",
    "body": "\\frac{d^{3} ${1:y}}{d ${2:x}^{3}}${0}",
    "description": "Third derivative d³y/dx³"
  },
  "Inner Product (comma notation)": {
    "prefix": "ipc",
    "body": "\\langle ${1:\\psi} , ${2:\\phi} \\rangle${0}",
    "description": "Inner product ⟨ψ,φ⟩"
  },
  "Outer Product": {
    "prefix": "oprod",
    "body": "| ${1:\\psi} \\rangle \\langle ${2:\\phi} |${0}",
    "description": "Outer product |ψ⟩⟨φ|"
  },
  "Double Right Arrow": {
    "prefix": "Rarr",
    "body": "\\Rightarrow${0}",
    "description": "Double right arrow ⟹"
  },
  "Math Text": {
    "prefix": "mtext",
    "body": "\\text{${1}}${0}",
    "description": "Text inside math mode"
  },
  "Bold Text": {
    "prefix": "bf",
    "body": "\\textbf{${1}}${0}",
    "description": "Bold text"
  },
  "Italic Text": {
    "prefix": "it",
    "body": "\\textit{${1}}${0}",
    "description": "Italic text"
  },
  "Ellipsis": {
    "prefix": "dots",
    "body": "\\dots${0}",
    "description": "Ellipsis \\dots"
  },
  "Big O / Order of Magnitude": {
    "prefix": "ord",
    "body": "\\mathcal{O}(${1:n^2})${0}",
    "description": "Big-O / order of magnitude"
  },
  "Math Bold": {
    "prefix": "mbo",
    "body": "\\mathbf{${1:v}}${0}",
    "description": "Bold math font \\mathbf"
  },
  "Congruence": {
    "prefix": "cong",
    "body": "\\cong${0}",
    "description": "Congruence ≅"
  },
  "Inline Math": {
    "prefix": "im",
    "body": "\\$${1}\\$${0}",
    "description": "Inline math $ $"
  },
  "Display Math": {
    "prefix": "dm",
    "body": "\\[\n\t${1}\n\\]${0}",
    "description": "Display math \\[ \\]"
  },
  "Partial Derivative": {
    "prefix": "pd",
    "body": "\\frac{\\partial ${1:f}}{\\partial ${2:x}}${0}",
    "description": "Partial derivative ∂f/∂x"
  },
  "First Order Total Derivative": {
    "prefix": "d1",
    "body": "\\frac{d ${1:y}}{d ${2:x}}${0}",
    "description": "First total derivative"
  },
  "Relativistic Energy": {
    "prefix": "enp",
    "body": "\\sqrt{\\mathbf{${1:p}}^2 + ${2:m}^2}${0}",
    "description": "Relativistic energy √(p²+m²)"
  },
  "Varpi": {
    "prefix": "varpi",
    "body": "\\varpi${0}",
    "description": "Variant pi ϖ"
  },
